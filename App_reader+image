        % Code that executes after component creation
        function startupFcn(app)
            % Skrij specifikacije motorja (nisem dal na UI panel zaenkrat)
            %poišči objekte s "Tagom"
            Skupina.Specifikacije = findobj(app.UIFigure, 'Tag', 'Specifikacije');
            set(Skupina.Specifikacije,'Visible', 'off');
            
            %Poveži in nastavi kamero
            imaqreset               % ponastavi naprave
            info = imaqhwinfo('winvideo');
            vid = videoinput('winvideo', 1, info.DeviceInfo.DefaultFormat); % npr. vid = videoinput('winvideo', 1, 'YUY2_640x480');
            triggerconfig(vid, 'manual'); %  Ročni prožilec
            set(vid, 'FramesPerTrigger', 1); % Koliko zajemov na prožitev
            set(vid, 'TriggerRepeat', Inf); % omogoči več sprožitev
            %start(vid); % zaženi video
            
            % predogled
            predogled = image(app.axPredogled, zeros(480, 640,3,'uint8')); % pripravi prostor za predogled. Ustvari črno okno, ki ga moramo skriti
            axis(app.axPredogled,'image') % Razmerje osi grafa kot jih ima kamera
            predogled.Visible = false;
            

            %% Izhodne spremenljivke
            app.Video = vid; %Video spremenljivka aplikacije
            app.Predogled = predogled;
            app.Skupina = Skupina;
            
        end

        % Callback function
        function BPButtonPushed(app, event)
            keyboard;
        end

        % Button pushed function: SCANButton
        function SCANButtonPushed(app, event)
            %% vhodne spremenljivke
            vid = app.Video;
            pred = app.Predogled;
            skupina = app.Skupina;
            %ax = app.axPredogled;
            
            %Skrij skupino
            set(skupina.Specifikacije, 'Visible', 'off')

            %% jedro
            pred.Visible = true;   
            start(vid); % zaženi video
            pause(0.2) % pavza mora biti, drugače je slika pomanjšana? Ko sem dal start(vid) za Visible mogoče pavza ni potrebna?
            preview(vid,pred) % predogled
             %ax.Visible = true; % prikaz slike

             while (1)
                %tic
                trigger(vid); % sproži nov zajem
                frame = getdata(vid,1); % pridobi prvo sliko v pomnilniku
                %imshow(frame); %Prikaži sliko
                %toc
                tekst = readBarcode(frame,'2D'); % tekst, ki je zapisan na kodi
                
            
                if strlength(tekst)

                [~,~,points] = readBarcode(frame);

                if ~isempty(points)

                    modules = 44;
                    warpSize = 440;   % large so modules are clear
                    moduleSize = 10;

                    %% DESTINATION (NO MARGIN)
                    dst = [1 1;
                        warpSize 1;
                        warpSize warpSize;
                        1 warpSize];

                    %% ORDER CORNERS
                    pts = points;
                    center = mean(pts,1);
                
                    top = pts(pts(:,2) < center(2), :);
                    bottom = pts(pts(:,2) >= center(2), :);
                
                    [~,i] = sort(top(:,1));
                    topLeft = top(i(1),:);
                    topRight = top(i(2),:);
                
                    [~,i] = sort(bottom(:,1));
                    bottomLeft = bottom(i(1),:);
                    bottomRight = bottom(i(2),:);
                
                    src = [topLeft;
                           topRight;
                           bottomRight;
                           bottomLeft];

                    %% WARP IMAGE
                    tform = fitgeotrans(src,dst,'projective');
                
                    warped = imwarp(frame,tform,...
                        'OutputView',imref2d([warpSize warpSize]),...
                        'InterpolationMethod','nearest');
                
                    %% BINARIZE
                    grayFrame = rgb2gray(warped);
                    T = adaptthresh(grayFrame,0.60);
                    bwFrame = imbinarize(grayFrame,T);
                    %% SAMPLE MODULES
                    cellSize = warpSize/modules;
                
                    dmGrid = false(modules,modules);
                
                    for r = 1:modules
                        for c = 1:modules
                
                            y = round((r-0.5)*cellSize);
                            x = round((c-0.5)*cellSize);
                
                            dmGrid(r,c) = bwFrame(y,x);
                
                        end
                    end
                
                    %% REDRAW CLEAN DATAMATRIX
                    drawnCode = imresize(dmGrid,moduleSize,'nearest');
                
                    displayImg = im2uint8(repmat(drawnCode,1,1,3));
                    end

                        %msg_tekst = sprintf("Podatki motorja:\n %s",tekst); % tekst za pojavno okno
                        %f = msgbox(msg_tekst); % pojavno okno z informacijo o prebranem ID
                    break;
                end
                %pause(0.1);
            end
            stop(vid); % Ustavi video
            
            pred.Visible = false; % to ne ustavi preview in še kaže ...
            
            % kliči prevajalnik. Nisem kar v tej funkciji, ker bo skoraj gotovo to tudi kasneje zunanja funkcija (po standardu)
           prevod = Magneti();        % create object
           prevod.parserV02(tekst); % parse QR text into properties

            %% Izpis
            app.SlikaQRkode.ImageSource = displayImg;
            app.StandardVrednostLabel.Text = prevod.standard;
            app.DPPVrednostLabel.Text = prevod.DPP;
            app.LifecycleVrednostLabel.Text = prevod.lifecycle;
            app.TypeVrednostLabel.Text = prevod.type;
            app.CharacteristicsVrednostLabel.Text = prevod.character;
            app.CoatingtypeVrednostLabel.Text = prevod.coating;
            app.ChemicalcompositionVrednostLabel.Text = prevod.chemicalcomp;
            app.GBDtechnologyVrednostLabel.Text = prevod.GBD;
            app.ManufacturingprocessVrednostLabel.Text = prevod.manuprocess;
            app.ShapeVrednostLabel.Text = prevod.shape;
            app.WeightVrednostLabel.Text = prevod.weight;
            app.DimensionsVrednostLabel.Text = prevod.dimension;
            app.TolerancesVrednostLabel.Text = prevod.tolerance;
            app.BRVrednostLabel.Text = prevod.BR;
            app.HCIVrednostLabel.Text = prevod.HCI;
            app.BHVrednostLabel.Text = prevod.BH;
            app.PermeabilityVrednostLabel.Text = prevod.permeability;
            app.MaximumworkingtempVrednostLabel.Text = prevod.maxtemp;
            app.GluetypeVrednostLabel.Text = prevod.glue;
            app.CompanyVrednostLabel.Text = prevod.company;
            app.PacketIDVrednostLabel.Text = prevod.ID;
            app.OriginVrednostLabel.Text = prevod.origin;
            app.TotalweightVrednostLabel.Text = prevod.totalweight;
            app.TotalnumberVrednostLabel.Text = prevod.count;
            app.MagnetizationVrednostLabel.Text = prevod.magnetization;
            app.CarbonfootprintVrednostLabel.Text = prevod.CO2;
            app.MotorproducerVrednostLabel.Text = prevod.motorprod;
            app.MotormodelVrednostLabel.Text = prevod.motormodel;
            

            %Prikaži skupino
            set(skupina.Specifikacije, 'Visible', 'on')

            %% izhodne spremenljivke
            app.Objekt = prevod;



        end
    end

