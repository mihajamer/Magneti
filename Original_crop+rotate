[~,~,points] = readBarcode(frame,'2D'); % get QR code corner points 
if ~isempty(points) % Optional margin around QR code 
margin = 10; % Calculate bounding rectangle from QR corners 

xMin = max(min(points(:,1)) - margin, 1);
xMax = min(max(points(:,1)) + margin, size(frame,2));
yMin = max(min(points(:,2)) - margin, 1);
yMax = min(max(points(:,2)) + margin, size(frame,1));

width = xMax - xMin; height = yMax - yMin; % Crop the frame to just the QR code area 

croppedFrame = imcrop(frame, [xMin yMin width height]); % Rotate the cropped frame so the bottom edge is horizontal 
bottomLeft = points(3,:) - [xMin-1, yMin-1]; % adjust points to cropped frame 
bottomRight = points(4,:) - [xMin-1, yMin-1];

angle = atan2d(bottomRight(2)-bottomLeft(2), bottomRight(1)-bottomLeft(1)); % Rotate image 

finalFrame = imrotate(croppedFrame, -angle, 'bicubic', 'crop');
